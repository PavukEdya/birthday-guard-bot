# ─── Telegram ────────────────────────────────────────────────────────────────
BOT_TOKEN=
# Negative integer for supergroups, e.g. -1001234567890
GROUP_CHAT_ID=

# ─── Google Sheets ───────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=
# Either a file path to the JSON key file, or the raw JSON string itself
GOOGLE_CREDENTIALS_JSON=

# ─── Birthday logic ──────────────────────────────────────────────────────────
REMOVE_BEFORE_DAYS=3
RETURN_AFTER_DAYS=2

# ─── Scheduler ───────────────────────────────────────────────────────────────
TIMEZONE=Europe/Moscow
CHECK_HOUR=9
CHECK_MINUTE=0

# ─── Storage ─────────────────────────────────────────────────────────────────
DB_PATH=data/birthday_guard.db

# ─── Logging ─────────────────────────────────────────────────────────────────
# "json" for production, "console" for local development
LOG_FORMAT=json
LOG_LEVEL=INFO
